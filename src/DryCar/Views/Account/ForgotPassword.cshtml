@{ ViewData["Title"] = "Parola sıfırlama"; }
<section class="container py-5" style="max-width: 560px">
    <h1>Parolanızı sıfırlayın</h1>
    @if (ViewBag.Error is string error) { <div class="alert alert-danger">@error</div> }
    @if (ViewBag.Success is string success) { <div class="alert alert-success">@success</div> }
    <form asp-action="ForgotPassword" method="post" class="vstack gap-3">
        <div><label for="email" class="form-label">E-posta</label><input id="email" name="email" type="email" class="form-control" required /></div>
        <button class="btn btn-primary" type="submit">Sıfırlama bağlantısı gönder</button>
    </form>
</section>
