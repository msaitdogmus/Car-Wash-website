@{ ViewData["Title"] = "Giriş"; }
<section class="container py-5" style="max-width: 560px">
    <h1 class="mb-4">Hesabınıza giriş yapın</h1>
    @if (ViewBag.Error is string error) { <div class="alert alert-danger">@error</div> }
    <form asp-action="Login" method="post" class="vstack gap-3">
        <div><label class="form-label" for="email">E-posta</label><input class="form-control" id="email" name="email" type="email" autocomplete="email" required /></div>
        <div><label class="form-label" for="password">Parola</label><input class="form-control" id="password" name="password" type="password" autocomplete="current-password" required /></div>
        <button class="btn btn-primary" type="submit">Devam et</button>
    </form>
    <div class="mt-3"><a asp-action="ForgotPassword">Parolamı unuttum</a></div>
</section>
