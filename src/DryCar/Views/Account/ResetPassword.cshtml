@model ResetPasswordViewModel
@{ ViewData["Title"] = "Yeni parola"; }
<section class="container py-5" style="max-width: 560px">
    <h1>Yeni parola belirleyin</h1>
    @if (ViewBag.Error is string error) { <div class="alert alert-danger">@error</div> }
    <form asp-action="ResetPassword" method="post" class="vstack gap-3">
        <input asp-for="Token" type="hidden" />
        <div><label asp-for="Password" class="form-label">Yeni parola</label><input asp-for="Password" class="form-control" minlength="10" /></div>
        <div><label asp-for="ConfirmPassword" class="form-label">Parola tekrarı</label><input asp-for="ConfirmPassword" class="form-control" minlength="10" /></div>
        <button class="btn btn-primary" type="submit">Parolayı güncelle</button>
    </form>
</section>
