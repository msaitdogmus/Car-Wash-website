@model IEnumerable<Appointment>
@{ ViewData["Title"] = "Geçmiş randevular"; }
<section class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4"><h1 class="mb-0">Geçmiş randevular</h1><form asp-action="ConfirmAllArchivedAppointments" method="post"><button class="btn btn-primary">Uygun kayıtların tümünü onayla</button></form></div>
    @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
    <div class="table-responsive"><table class="table align-middle"><thead><tr><th>Müşteri</th><th>Hizmet</th><th>Tarih</th><th>Durum</th><th></th></tr></thead><tbody>
    @foreach (var appointment in Model) { <tr><td>@appointment.User?.FirstName @appointment.User?.LastName</td><td>@appointment.Service?.Name</td><td>@appointment.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td><td>@(appointment.IsConfirmed ? "Onaylandı" : "Bekliyor")</td><td class="text-end">@if (!appointment.IsConfirmed) { <form asp-action="ConfirmArchivedAppointment" asp-route-id="@appointment.Id" method="post" class="d-inline"><button class="btn btn-sm btn-success">Onayla</button></form> } <form asp-action="DeleteArchivedAppointment" asp-route-id="@appointment.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger">Sil</button></form></td></tr> }
    </tbody></table></div>
</section>
