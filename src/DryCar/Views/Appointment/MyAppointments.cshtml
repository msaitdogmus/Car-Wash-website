@model IEnumerable<Appointment>
@{ ViewData["Title"] = "Randevularım"; }
<section class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4"><h1 class="mb-0">Yaklaşan randevularım</h1><a class="btn btn-primary" asp-action="Book">Yeni randevu</a></div>
    <div class="table-responsive"><table class="table align-middle"><thead><tr><th>Hizmet</th><th>Tarih</th><th>Durum</th><th></th></tr></thead><tbody>
    @foreach (var appointment in Model) {
        <tr><td>@appointment.Service?.Name</td><td>@appointment.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td><td>@(appointment.IsConfirmed ? "Onaylandı" : "Onay bekliyor")</td><td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@appointment.Id">Düzenle</a><form asp-action="Delete" asp-route-id="@appointment.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger" type="submit">İptal</button></form></td></tr>
    }
    </tbody></table></div>
</section>
