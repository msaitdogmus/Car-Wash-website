<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - DryCar Care</title>
    <link rel="icon" href="~/favicon.ico" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom bg-dark">
        <nav class="navbar navbar-expand-lg navbar-dark container py-3">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">DryCar Care</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div id="mainNav" class="collapse navbar-collapse">
                <div class="navbar-nav ms-auto gap-lg-2">
                    <a class="nav-link" asp-controller="Home" asp-action="About">Hakkımızda</a>
                    <a class="nav-link" asp-controller="Appointment" asp-action="Book">Randevu al</a>
                    @if (Context.Session.GetInt32("UserId").HasValue)
                    {
                        <a class="nav-link" asp-controller="Appointment" asp-action="MyAppointments">Randevularım</a>
                        <a class="nav-link" asp-controller="Account" asp-action="Logout">Çıkış</a>
                    }
                    else
                    {
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Giriş</a>
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Kayıt</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="container mt-3"><div class="alert alert-success">@success</div></div>
        }
        @if (TempData["NotificationMessage"] is string notification)
        {
            <div class="container mt-3"><div class="alert alert-info">@notification</div></div>
        }
        @RenderBody()
    </main>

    <footer class="border-top mt-5 py-4">
        <div class="container d-flex flex-wrap justify-content-between gap-2 small text-secondary">
            <span>© @DateTime.Now.Year DryCar Care</span>
            <span>
                <a asp-controller="Home" asp-action="Kvkk">KVKK</a> ·
                <a asp-controller="Home" asp-action="Gizlilik">Gizlilik</a> ·
                <a asp-controller="Home" asp-action="Cookies">Çerezler</a>
            </span>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
